{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "es2024",
        "module": "commonjs",              
        "moduleResolution": "node",    
        "ignoreDeprecations": "6.0",   
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "types": ["jest", "node"], 
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules"]
}