{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "es2024",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "types": ["jest"],
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}