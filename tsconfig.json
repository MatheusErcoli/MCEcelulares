{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "es2024",
        "module": "commonjs",
        "rootDir": ".",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "types": ["jest"],
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules"]
}